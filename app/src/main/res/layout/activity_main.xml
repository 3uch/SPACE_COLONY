<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:text="🚀 Choose Your Crew"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnSoldier"
        android:text="💂 Soldier"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnMedic"
        android:text="❤️ Medic"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnEngineer"
        android:text="⚙️ Engineer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnScientist"
        android:text="🧪 Scientist"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnPilot"
        android:text="👨‍✈️ Pilot"
        android:layout_width="match_parent"
        android:layout_height="60dp"/>

</LinearLayout>